nextflow.enable.dsl=2

import java.time.*
Date now = new Date()

// ─── Parameters ───────────────────────────────────────────────────────────────
params {
    // ── Sequencing platform ───────────────────────────────────────────────────
    // 'ont'      — Oxford Nanopore (single-end, long reads)
    // 'illumina' — Illumina short reads (paired-end, R1/R2)
    platform = 'ont'

    // ── Input mode (pick ONE) ─────────────────────────────────────────────────
    // 1. ONT: local FASTQ folder (one file per sample)
    reads       = null

    // 2. ONT: barcode directory produced by Guppy/MinKNOW
    //    Each sub-folder (barcode01/, barcode02/, …) is one sample.
    barcode_dir = null

    // 3. ONT: SRA accession list (one SRR/ERR per line)
    sra_list    = null

    // 4. Illumina: glob matching R1 files — R2 is inferred automatically.
    //    Pattern must contain {1,2} or _R1/_R2 so Nextflow can pair them.
    //    Example: "illumina_reads/*_R1.fastq.gz"
    illumina_reads = null

    // ── Sample sheet (optional, ONT barcode mode only) ────────────────────────
    // TSV with two columns: barcode <TAB> sample_name
    // Renames barcodes to meaningful sample IDs before analysis.
    // If omitted, folder names (barcode01, …) are used as sample IDs.
    sample_sheet = null

    // Output
    outdir    = "Results"

    // Resource limits
    max_cpu    = 14
    max_memory = '14GB'
    max_time   = '24h'

    // ── Serovar selection ─────────────────────────────────────────────────────
    // Set serovar name to auto-select a reference genome from the built-in table.
    // Supported values: Infantis, Typhimurium, Enteritidis, Newport, Heidelberg,
    //                   Dublin, Kentucky, Stanley, Agona, Virchow, Thompson,
    //                   Choleraesuis, Typhi, Paratyphi_A, Paratyphi_B
    // Set to null to use ref_genome directly (local file or 'auto' = download).
    serovar = 'Infantis'

    // NCBI assembly accessions for common Salmonella serovars.
    // These are fetched automatically when ref_genome is null or 'auto'.
    serovar_refs = [
        'Infantis'     : 'GCA_000953495.1',   // LN649235.1
        'Typhimurium'  : 'GCA_000006945.2',   // AE006468.2 — LT2
        'Enteritidis'  : 'GCA_000009505.1',   // AM933172.1 — P125109
        'Newport'      : 'GCA_016028075.1',   // CP070232.1
        'Heidelberg'   : 'GCA_000026565.1',   // CP002876.1 — SL476
        'Dublin'       : 'GCA_000260195.1',   // FM200053.1
        'Kentucky'     : 'GCA_000020185.1',   // CP001120.1 — CVM29188
        'Stanley'      : 'GCA_000014965.1',   // CP000026.1
        'Agona'        : 'GCA_000176875.1',   // CP002639.1 — SL483
        'Virchow'      : 'GCA_001022215.1',   // LN999985.1
        'Thompson'     : 'GCA_000333095.1',   // CP003386.1 — RM6836
        'Choleraesuis' : 'GCA_000007645.1',   // AE017220.1 — SC-B67
        'Typhi'        : 'GCA_000195995.1',   // AL513382.1 — CT18
        'Paratyphi_A'  : 'GCA_000011885.1',   // AE014613.1 — ATCC 9150
        'Paratyphi_B'  : 'GCA_000020705.1',   // AM412236.1 — SPB7
    ]

    // snpEff database per serovar (falls back to Salmonella_enterica)
    serovar_snpeff = [
        'Typhimurium' : 'Salmonella_enterica_serovar_Typhimurium_str_LT2',
        'Enteritidis' : 'Salmonella_enterica_serovar_Enteritidis_str_P125109',
        'Typhi'       : 'Salmonella_enterica_serovar_Typhi_str_CT18',
        'Paratyphi_A' : 'Salmonella_enterica_serovar_Paratyphi_A_str_ATCC_9150',
    ]

    // Reference genome: path to a local FASTA file.
    // Set to null (default) to auto-download based on serovar.
    ref_genome = null

    // Assembly genome size estimate — Salmonella is ~5 Mb for all serovars.
    // Adjust for other species (e.g. '4.5m' for smaller genomes).
    genome_size = '5m'

    // cgMLST / chewBBACA schema parameters
    // Salmonella enterica = species 8 in Chewie-NS; schema 1 covers all serovars.
    cgmlst_species_id = 8
    cgmlst_schema_id  = 1

    // Database / tool paths
    kraken2_db       = "/home/analysis/kraken2_db"
    clair3_model     = "/opt/models/r941_prom_hac_g360+g422"
    bakta_db         = "/home/analysis/bakta_db"
    plasmidfinder_db = "/home/analysis/plasmidfinder_db"
    snpeff_db        = null   // resolved from serovar_snpeff map, or Salmonella_enterica

    // Tracing
    tracedir  = "pipeline_info"
    timestamp = now.format("yyyyMMdd-HH-mm-ss")
}

// ─── Reporting ────────────────────────────────────────────────────────────────
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.tracedir}/${params.timestamp}_timeline.html"
}
report {
    enabled   = true
    overwrite = true
    file      = "${params.tracedir}/${params.timestamp}_report.html"
}

// ─── Default Process Settings ─────────────────────────────────────────────────
process {
    cpus          = { Math.min(4, params.max_cpu as int) }
    memory        = params.max_memory
    time          = params.max_time
    errorStrategy = 'retry'
    maxRetries    = 1
}

// ─── Profiles ─────────────────────────────────────────────────────────────────
profiles {

    // ── Standard (tools must be available in PATH) ───────────────────────────
    standard {
        process.executor = 'local'
    }

    // ── Conda ────────────────────────────────────────────────────────────────
    // Usage: nextflow run main.nf -profile conda --reads "*.fastq" -c config/nextflow.config
    conda {
        conda.enabled    = true
        conda.useMamba   = true          // mamba is strongly recommended for this pipeline
        process.executor = 'local'

        // Global environment — applies to all processes unless overridden below
        process.conda = "${projectDir}/environment.yaml"

        // chewBBACA, Clair3, and PopPUNK run in isolated environments
        // to avoid Python dependency conflicts with other tools
        process {
            withName: 'CGMLST'  { conda = "${projectDir}/config/envs/cgmlst.yaml"  }
            withName: 'CLAIR3'  { conda = "${projectDir}/config/envs/clair3.yaml"  }
            withName: 'POPPUNK' { conda = "${projectDir}/config/envs/poppunk.yaml" }
        }
    }

    // ── Docker ───────────────────────────────────────────────────────────────
    // Usage: nextflow run main.nf -profile docker --reads "*.fastq" -c config/nextflow.config
    // Build images first:
    //   docker build -t cinnetcrash/gelidonyamr:latest .
    //   docker build -f docker/Dockerfile.cgmlst  -t cinnetcrash/gelidonyamr-cgmlst:latest  .
    //   docker build -f docker/Dockerfile.clair3  -t cinnetcrash/gelidonyamr-clair3:latest  .
    //   docker build -f docker/Dockerfile.poppunk -t cinnetcrash/gelidonyamr-poppunk:latest .
    docker {
        docker.enabled    = true
        docker.runOptions = '--rm -u $(id -u):$(id -g)'
        process.executor  = 'local'

        process.container = 'cinnetcrash/gelidonyamr:latest'

        process {
            withName: 'CGMLST'  { container = 'cinnetcrash/gelidonyamr-cgmlst:latest'  }
            withName: 'CLAIR3'  { container = 'cinnetcrash/gelidonyamr-clair3:latest'   }
            withName: 'POPPUNK' { container = 'cinnetcrash/gelidonyamr-poppunk:latest'  }
        }
    }

    // ── Singularity (HPC without Docker) ────────────────────────────────────
    // Usage: nextflow run main.nf -profile singularity --reads "*.fastq" -c config/nextflow.config
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.executor       = 'local'

        process.container = 'docker://cinnetcrash/gelidonyamr:latest'

        process {
            withName: 'CGMLST'  { container = 'docker://cinnetcrash/gelidonyamr-cgmlst:latest'  }
            withName: 'CLAIR3'  { container = 'docker://cinnetcrash/gelidonyamr-clair3:latest'   }
            withName: 'POPPUNK' { container = 'docker://cinnetcrash/gelidonyamr-poppunk:latest'  }
        }
    }

    // ── SLURM + Conda (HPC cluster) ──────────────────────────────────────────
    // Usage: nextflow run main.nf -profile slurm,conda --reads "*.fastq" -c config/nextflow.config
    slurm {
        process.executor = 'slurm'
        process.queue    = 'main'
    }
}

// ─── Executor ─────────────────────────────────────────────────────────────────
executor {
    queueSize = 3
}

env {
    JAVA_OPTS = '-Xmx14g'
}
