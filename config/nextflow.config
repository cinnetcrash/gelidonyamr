nextflow.enable.dsl=2

import java.time.*
Date now = new Date()

// ─── Parameters ───────────────────────────────────────────────────────────────
params {
    // ── Sequencing platform ───────────────────────────────────────────────────
    // 'ont'      — Oxford Nanopore (single-end, long reads)
    // 'illumina' — Illumina short reads (paired-end, R1/R2)
    platform = 'ont'

    // ── Input mode (pick ONE) ─────────────────────────────────────────────────
    // 1. ONT: local FASTQ folder (one file per sample)
    reads       = null

    // 2. ONT: barcode directory produced by Guppy/MinKNOW
    //    Each sub-folder (barcode01/, barcode02/, …) is one sample.
    barcode_dir = null

    // 3. ONT: SRA accession list (one SRR/ERR per line)
    sra_list    = null

    // 4. Illumina: glob matching R1 files — R2 is inferred automatically.
    //    Pattern must contain {1,2} or _R1/_R2 so Nextflow can pair them.
    //    Example: "illumina_reads/*_R1.fastq.gz"
    illumina_reads = null

    // ── Sample sheet (optional, ONT barcode mode only) ────────────────────────
    // TSV with two columns: barcode <TAB> sample_name
    // Renames barcodes to meaningful sample IDs before analysis.
    // If omitted, folder names (barcode01, …) are used as sample IDs.
    sample_sheet = null

    // Output
    outdir    = "Results"

    // Resource limits
    max_cpu    = 14
    max_memory = '14GB'
    max_time   = '24h'

    // ── Serovar selection ─────────────────────────────────────────────────────
    // Set serovar name to auto-select a reference genome from the built-in table.
    // Supported values: Infantis, Typhimurium, Enteritidis, Newport, Heidelberg,
    //                   Dublin, Kentucky, Stanley, Agona, Virchow, Thompson,
    //                   Choleraesuis, Typhi, Paratyphi_A, Paratyphi_B
    // Set to null to use ref_genome directly (local file or 'auto' = download).
    serovar = 'Infantis'

    // NCBI assembly accessions for common Salmonella serovars.
    // These are fetched automatically when ref_genome is null or 'auto'.
    serovar_refs = [
        'Infantis'     : 'GCA_000953495.1',   // LN649235.1
        'Typhimurium'  : 'GCA_000006945.2',   // AE006468.2 — LT2
        'Enteritidis'  : 'GCA_000009505.1',   // AM933172.1 — P125109
        'Newport'      : 'GCA_016028075.1',   // CP070232.1
        'Heidelberg'   : 'GCA_000026565.1',   // CP002876.1 — SL476
        'Dublin'       : 'GCA_000260195.1',   // FM200053.1
        'Kentucky'     : 'GCA_000020185.1',   // CP001120.1 — CVM29188
        'Stanley'      : 'GCA_000014965.1',   // CP000026.1
        'Agona'        : 'GCA_000176875.1',   // CP002639.1 — SL483
        'Virchow'      : 'GCA_001022215.1',   // LN999985.1
        'Thompson'     : 'GCA_000333095.1',   // CP003386.1 — RM6836
        'Choleraesuis' : 'GCA_000007645.1',   // AE017220.1 — SC-B67
        'Typhi'        : 'GCA_000195995.1',   // AL513382.1 — CT18
        'Paratyphi_A'  : 'GCA_000011885.1',   // AE014613.1 — ATCC 9150
        'Paratyphi_B'  : 'GCA_000020705.1',   // AM412236.1 — SPB7
    ]

    // snpEff database per serovar (falls back to Salmonella_enterica)
    serovar_snpeff = [
        'Typhimurium' : 'Salmonella_enterica_serovar_Typhimurium_str_LT2',
        'Enteritidis' : 'Salmonella_enterica_serovar_Enteritidis_str_P125109',
        'Typhi'       : 'Salmonella_enterica_serovar_Typhi_str_CT18',
        'Paratyphi_A' : 'Salmonella_enterica_serovar_Paratyphi_A_str_ATCC_9150',
    ]

    // Reference genome: path to a local FASTA file.
    // Set to null (default) to auto-download based on serovar.
    ref_genome = null

    // ── Assembly options ─────────────────────────────────────────────────────
    // 'flye'       — Flye + Racon polishing (default, ONT only)
    // 'autocycler' — Flye + Miniasm + Raven → Autocycler consensus (ONT only)
    // 'spades'     — SPAdes (Illumina only, set automatically)
    assembler = 'flye'

    // Assembly genome size estimate — Salmonella is ~5 Mb for all serovars.
    genome_size = '5m'

    // ── Optional analyses ────────────────────────────────────────────────────
    // Pan-genome analysis (Roary + IQ-TREE from pan-genome alignment)
    run_pangenome = false

    // ── Context genomes for phylogenomics ────────────────────────────────────
    // Downloads public genomes from NCBI for inclusion in the phylogenetic tree.
    // Set run_context_genomes = false to skip (use only your own samples).
    run_context_genomes  = true
    context_per_country  = 5     // max genomes per country
    context_max_total    = 100   // hard cap on total downloads

    // ── cgMLST / chewBBACA schema ────────────────────────────────────────────
    // Salmonella enterica = species 8 in Chewie-NS; schema 1 covers all serovars.
    cgmlst_species_id = 8
    cgmlst_schema_id  = 1

    // ── Database / tool paths ────────────────────────────────────────────────
    kraken2_db   = "/home/analysis/kraken2_db"
    clair3_model = "/opt/models/r941_prom_hac_g360+g422"
    bakta_db     = "/home/analysis/bakta_db"
    snpeff_db    = null   // resolved from serovar_snpeff map, or Salmonella_enterica

    // Tracing
    tracedir  = "pipeline_info"
    timestamp = now.format("yyyyMMdd-HH-mm-ss")
}

// ─── Reporting ────────────────────────────────────────────────────────────────
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.tracedir}/${params.timestamp}_timeline.html"
}
report {
    enabled   = true
    overwrite = true
    file      = "${params.tracedir}/${params.timestamp}_report.html"
}

// ─── Default Process Settings ─────────────────────────────────────────────────
process {
    cpus          = { Math.min(4, params.max_cpu as int) }
    memory        = params.max_memory
    time          = params.max_time
    errorStrategy = 'retry'
    maxRetries    = 1
}

// ─── Profiles ─────────────────────────────────────────────────────────────────
profiles {

    // ── Standard (tools must be available in PATH) ───────────────────────────
    standard {
        process.executor = 'local'
    }

    // ── Conda ────────────────────────────────────────────────────────────────
    // Usage: nextflow run main.nf -profile conda --reads "*.fastq" -c config/nextflow.config
    conda {
        conda.enabled    = true
        conda.useMamba   = true          // mamba is strongly recommended for this pipeline
        process.executor = 'local'

        // Global environment — applies to all processes unless overridden below
        process.conda = "${projectDir}/environment.yaml"

        // chewBBACA, Clair3, and PopPUNK run in isolated environments
        // to avoid Python dependency conflicts with other tools
        process {
            withName: 'CGMLST'  { conda = "${projectDir}/config/envs/cgmlst.yaml"  }
            withName: 'CLAIR3'  { conda = "${projectDir}/config/envs/clair3.yaml"  }
            withName: 'POPPUNK' { conda = "${projectDir}/config/envs/poppunk.yaml" }
        }
    }

    // ── Docker ───────────────────────────────────────────────────────────────
    // Usage: nextflow run main.nf -profile docker --reads "*.fastq" -c config/nextflow.config
    // Build images first:
    // ── Docker — per-process BioContainers (no custom build required) ───────
    // Usage: nextflow run main.nf -profile docker --platform ont --barcode_dir /path/fastq_pass -c config/nextflow.config
    // All images are pulled automatically from Docker Hub / quay.io on first run.
    docker {
        docker.enabled    = true
        docker.runOptions = '--rm'
        process.executor  = 'local'

        process {
            // ── Input / merge ───────────────────────────────────────────────
            withName: 'MERGE_BARCODES'    { container = 'ubuntu:22.04' }
            withName: 'SRA_DOWNLOAD'      { container = 'quay.io/biocontainers/sra-tools:3.1.1--h4304569_0' }
            withName: 'FETCH_REFERENCE'   { container = 'python:3.11-slim' }  // uses Python urllib

            // ── QC ──────────────────────────────────────────────────────────
            withName: 'FASTQC'            { container = 'staphb/fastqc:0.12.1' }
            withName: 'TRIMMING'          { container = 'staphb/fastp:0.23.2' }
            withName: 'TRIMMING_ILLUMINA' { container = 'staphb/fastp:0.23.2' }
            withName: 'KRAKEN2'           { container = 'staphb/kraken2:2.1.3' }
            withName: 'MULTIQC'           { container = 'staphb/multiqc:1.19' }

            // ── Assembly & polishing ─────────────────────────────────────────
            withName: 'ASSEMBLY'          { container = 'staphb/flye:2.9.1' }
            withName: 'ASSEMBLY_ILLUMINA' { container = 'staphb/spades:4.0.0' }
            withName: 'RACON'             { container = 'quay.io/biocontainers/racon:1.5.0--h21ec9f0_2' }

            // ── Assembly QC ──────────────────────────────────────────────────
            withName: 'QUAST'             { container = 'staphb/quast:5.2.0' }
            withName: 'BUSCO'             { container = 'quay.io/biocontainers/busco:5.7.1--pyhdfd78af_0' }
            withName: 'CHECKM'            { container = 'quay.io/biocontainers/checkm-genome:1.2.3--pyhdfd78af_0' }
            withName: 'FASTANI'           { container = 'quay.io/biocontainers/fastani:1.34--h2e03b76_0' }

            // ── Annotation ──────────────────────────────────────────────────
            withName: 'BAKTA_CHROMOSOME'  { container = 'quay.io/biocontainers/bakta:1.9.4--pyhdfd78af_0' }
            withName: 'BAKTA_PLASMID'     { container = 'quay.io/biocontainers/bakta:1.9.4--pyhdfd78af_0' }

            // ── AMR ─────────────────────────────────────────────────────────
            withName: 'AMRFINDER_CHROM'   { container = 'staphb/ncbi-amrfinderplus:3.12.8' }
            withName: 'AMRFINDER_PLASMID' { container = 'staphb/ncbi-amrfinderplus:3.12.8' }

            // ── Plasmid ─────────────────────────────────────────────────────
            withName: 'MOBSUITE'          { container = 'quay.io/biocontainers/mob_suite:3.1.9--pyhdfd78af_0' }
            withName: 'PLASMIDFINDER'     { container = 'staphb/plasmidfinder:2.1.6' }

            // ── Typing ──────────────────────────────────────────────────────
            withName: 'MLST'              { container = 'staphb/mlst:2.23.0' }
            withName: 'CGMLST'            { container = 'quay.io/biocontainers/chewbbaca:3.3.6--pyhdfd78af_0' }

            // ── Variant calling ─────────────────────────────────────────────
            withName: 'CLAIR3'            { container = 'hkubal/clair3:latest' }
            withName: 'SNPEFF'            { container = 'quay.io/biocontainers/snpeff:5.2--hdfd78af_1' }
            withName: 'SNIPPY'            { container = 'staphb/snippy:4.6.0' }

            // ── Prophage ────────────────────────────────────────────────────
            withName: 'PHASTEST'          { container = 'ubuntu:22.04' }  // web API only

            // ── Plasmid annotation ───────────────────────────────────────────
            withName: 'SPLIT_MOB_OUTPUT'  { container = 'ubuntu:22.04' }
            withName: 'BAKTA_FASTA'       { container = 'quay.io/biocontainers/bakta:1.9.4--pyhdfd78af_0' }
            withName: 'PLANNOTATE'        { container = 'quay.io/biocontainers/plannotate:0.6.7--pyhdfd78af_0' }

            // ── Autocycler assembly ──────────────────────────────────────────
            withName: 'ASSEMBLY_AUTOCYCLER' { container = 'ubuntu:22.04' }  // must be in PATH (conda)

            // ── Context genomes ──────────────────────────────────────────────
            withName: 'FETCH_CONTEXT_GENOMES' { container = 'python:3.11-slim' }

            // ── Phylogenomics ────────────────────────────────────────────────
            withName: 'PARSNP'            { container = 'staphb/parsnp:2.0.4' }
            withName: 'ROARY'             { container = 'staphb/roary:3.13.0' }
            withName: 'IQTREE'            { container = 'quay.io/biocontainers/iqtree:2.3.5--h21ec9f0_0' }
            withName: 'POPPUNK'           { container = 'quay.io/biocontainers/poppunk:2.6.5--py39h7cff6ad_2' }
        }
    }

    // ── Singularity (HPC without Docker) ────────────────────────────────────
    // Usage: nextflow run main.nf -profile singularity -c config/nextflow.config
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.executor       = 'local'

        process {
            withName: 'MERGE_BARCODES'    { container = 'docker://ubuntu:22.04' }
            withName: 'SRA_DOWNLOAD'      { container = 'docker://quay.io/biocontainers/sra-tools:3.1.1--h4304569_0' }
            withName: 'FETCH_REFERENCE'   { container = 'docker://python:3.11-slim' }
            withName: 'FASTQC'            { container = 'docker://staphb/fastqc:0.12.1' }
            withName: 'TRIMMING'          { container = 'docker://staphb/fastp:0.23.2' }
            withName: 'TRIMMING_ILLUMINA' { container = 'docker://staphb/fastp:0.23.2' }
            withName: 'KRAKEN2'           { container = 'docker://staphb/kraken2:2.1.3' }
            withName: 'MULTIQC'           { container = 'docker://staphb/multiqc:1.19' }
            withName: 'ASSEMBLY'          { container = 'docker://staphb/flye:2.9.1' }
            withName: 'ASSEMBLY_ILLUMINA' { container = 'docker://staphb/spades:4.0.0' }
            withName: 'RACON'             { container = 'docker://quay.io/biocontainers/racon:1.5.0--h21ec9f0_2' }
            withName: 'QUAST'             { container = 'docker://staphb/quast:5.2.0' }
            withName: 'BUSCO'             { container = 'docker://quay.io/biocontainers/busco:5.7.1--pyhdfd78af_0' }
            withName: 'CHECKM'            { container = 'docker://quay.io/biocontainers/checkm-genome:1.2.3--pyhdfd78af_0' }
            withName: 'FASTANI'           { container = 'docker://quay.io/biocontainers/fastani:1.34--h2e03b76_0' }
            withName: 'BAKTA_CHROMOSOME'  { container = 'docker://quay.io/biocontainers/bakta:1.9.4--pyhdfd78af_0' }
            withName: 'BAKTA_PLASMID'     { container = 'docker://quay.io/biocontainers/bakta:1.9.4--pyhdfd78af_0' }
            withName: 'AMRFINDER_CHROM'   { container = 'docker://staphb/ncbi-amrfinderplus:3.12.8' }
            withName: 'AMRFINDER_PLASMID' { container = 'docker://staphb/ncbi-amrfinderplus:3.12.8' }
            withName: 'MOBSUITE'          { container = 'docker://quay.io/biocontainers/mob_suite:3.1.9--pyhdfd78af_0' }
            withName: 'PLASMIDFINDER'     { container = 'docker://staphb/plasmidfinder:2.1.6' }
            withName: 'MLST'              { container = 'docker://staphb/mlst:2.23.0' }
            withName: 'CGMLST'            { container = 'docker://quay.io/biocontainers/chewbbaca:3.3.6--pyhdfd78af_0' }
            withName: 'CLAIR3'            { container = 'docker://hkubal/clair3:latest' }
            withName: 'SNPEFF'            { container = 'docker://quay.io/biocontainers/snpeff:5.2--hdfd78af_1' }
            withName: 'SNIPPY'            { container = 'docker://staphb/snippy:4.6.0' }
            withName: 'PHASTER'           { container = 'docker://ubuntu:22.04' }
            withName: 'PARSNP'            { container = 'docker://staphb/parsnp:2.0.4' }
            withName: 'ROARY'             { container = 'docker://staphb/roary:3.13.0' }
            withName: 'IQTREE'            { container = 'docker://quay.io/biocontainers/iqtree:2.3.5--h21ec9f0_0' }
            withName: 'POPPUNK'           { container = 'docker://quay.io/biocontainers/poppunk:2.6.5--py39h7cff6ad_2' }
        }
    }

    // ── SLURM + Conda (HPC cluster) ──────────────────────────────────────────
    // Usage: nextflow run main.nf -profile slurm,conda --reads "*.fastq" -c config/nextflow.config
    slurm {
        process.executor = 'slurm'
        process.queue    = 'main'
    }
}

// ─── Executor ─────────────────────────────────────────────────────────────────
executor {
    queueSize = 3
}

env {
    JAVA_OPTS = '-Xmx14g'
}
