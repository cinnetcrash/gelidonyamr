nextflow.enable.dsl=2

import java.time.*
Date now = new Date()

// ─── Parameters ───────────────────────────────────────────────────────────────
params {
    // Input
    sra_list  = null
    reads     = "input_folder/*.fastq"

    // Output
    outdir    = "Results"

    // Resource limits
    max_cpu    = 14
    max_memory = '14GB'
    max_time   = '24h'

    // Database / reference paths
    kraken2_db       = "/home/analysis/kraken2_db"
    ref_genome       = "data/ref_genome.fna"
    clair3_model     = "/opt/models/r941_prom_hac_g360+g422"
    bakta_db         = "/home/analysis/bakta_db"
    plasmidfinder_db = "/home/analysis/plasmidfinder_db"
    snpeff_db        = "Salmonella_enterica"

    // Tracing
    tracedir  = "pipeline_info"
    timestamp = now.format("yyyyMMdd-HH-mm-ss")
}

// ─── Reporting ────────────────────────────────────────────────────────────────
timeline {
    enabled = true
    file    = "${params.tracedir}/${params.timestamp}_timeline.html"
}
report {
    enabled = true
    file    = "${params.tracedir}/${params.timestamp}_report.html"
}

// ─── Default Process Settings ─────────────────────────────────────────────────
process {
    cpus          = { Math.min(4, params.max_cpu as int) }
    memory        = params.max_memory
    time          = params.max_time
    errorStrategy = 'retry'
    maxRetries    = 1
}

// ─── Profiles ─────────────────────────────────────────────────────────────────
profiles {

    // ── Standard (tools must be available in PATH) ───────────────────────────
    standard {
        process.executor = 'local'
    }

    // ── Conda ────────────────────────────────────────────────────────────────
    // Usage: nextflow run main.nf -profile conda --reads "*.fastq" -c config/nextflow.config
    conda {
        conda.enabled    = true
        conda.useMamba   = true          // mamba is strongly recommended for this pipeline
        process.executor = 'local'

        // Global environment — applies to all processes unless overridden below
        process.conda = "${projectDir}/environment.yaml"

        // chewBBACA, Clair3, and PopPUNK run in isolated environments
        // to avoid Python dependency conflicts with other tools
        process {
            withName: 'CGMLST'  { conda = "${projectDir}/config/envs/cgmlst.yaml"  }
            withName: 'CLAIR3'  { conda = "${projectDir}/config/envs/clair3.yaml"  }
            withName: 'POPPUNK' { conda = "${projectDir}/config/envs/poppunk.yaml" }
        }
    }

    // ── Docker ───────────────────────────────────────────────────────────────
    // Usage: nextflow run main.nf -profile docker --reads "*.fastq" -c config/nextflow.config
    // Build images first:
    //   docker build -t cinnetcrash/gelidonyamr:latest .
    //   docker build -f docker/Dockerfile.cgmlst  -t cinnetcrash/gelidonyamr-cgmlst:latest  .
    //   docker build -f docker/Dockerfile.clair3  -t cinnetcrash/gelidonyamr-clair3:latest  .
    //   docker build -f docker/Dockerfile.poppunk -t cinnetcrash/gelidonyamr-poppunk:latest .
    docker {
        docker.enabled    = true
        docker.runOptions = '--rm -u $(id -u):$(id -g)'
        process.executor  = 'local'

        process.container = 'cinnetcrash/gelidonyamr:latest'

        process {
            withName: 'CGMLST'  { container = 'cinnetcrash/gelidonyamr-cgmlst:latest'  }
            withName: 'CLAIR3'  { container = 'cinnetcrash/gelidonyamr-clair3:latest'   }
            withName: 'POPPUNK' { container = 'cinnetcrash/gelidonyamr-poppunk:latest'  }
        }
    }

    // ── Singularity (HPC without Docker) ────────────────────────────────────
    // Usage: nextflow run main.nf -profile singularity --reads "*.fastq" -c config/nextflow.config
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        process.executor       = 'local'

        process.container = 'docker://cinnetcrash/gelidonyamr:latest'

        process {
            withName: 'CGMLST'  { container = 'docker://cinnetcrash/gelidonyamr-cgmlst:latest'  }
            withName: 'CLAIR3'  { container = 'docker://cinnetcrash/gelidonyamr-clair3:latest'   }
            withName: 'POPPUNK' { container = 'docker://cinnetcrash/gelidonyamr-poppunk:latest'  }
        }
    }

    // ── SLURM + Conda (HPC cluster) ──────────────────────────────────────────
    // Usage: nextflow run main.nf -profile slurm,conda --reads "*.fastq" -c config/nextflow.config
    slurm {
        process.executor = 'slurm'
        process.queue    = 'main'
    }
}

// ─── Executor ─────────────────────────────────────────────────────────────────
executor {
    queueSize = 3
}

env {
    JAVA_OPTS = '-Xmx14g'
}
